# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin email (이 이메일로 로그인하면 관리자 대시보드 접근 가능)
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# Airtable (B안: 진도 현황 뷰어)
AIRTABLE_PERSONAL_TOKEN=pat_xxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# 동기화 API 인증 키 (임의의 문자열 설정)
SYNC_API_KEY=your-random-sync-key-here
NEXT_PUBLIC_SYNC_API_KEY=your-random-sync-key-here

# Vercel Cron이 POST /api/sync/airtable 호출 시 사용 (Vercel 대시보드 CRON_SECRET과 동일)
CRON_SECRET=your-random-cron-secret-here

# 샘플 수강생 자동 생성 시 사용할 임시 비밀번호 (선택)
SAMPLE_STUDENT_PASSWORD=Sample1234!
